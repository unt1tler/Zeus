# Admin login
LOGIN_EMAIL=admin@example.com
LOGIN_PASSWORD=change-this-password

# Required for signed admin, client, and OAuth state cookies.
# Use a long random value in production.
SESSION_SECRET=change-this-to-a-long-random-secret

# Web server
PORT=9002
SESSION_COOKIE_SECURE=false
TRUST_X_FORWARDED_FOR=false

# Storage
# JSON file storage is used by default. Set DB=POSTGRESQL to use PostgreSQL.
DB=JSON

# PostgreSQL storage
# DB=POSTGRESQL
# postgresql_db=postgres://user:password@host:5432/database?sslmode=require
# PostgreSQL table prefix. Creates tables such as zeus_store_products and zeus_store_licenses.
# POSTGRESQL_TABLE=zeus_store
# POSTGRESQL_POOL_MAX=10
# POSTGRESQL_CONNECT_TIMEOUT_MS=10000
# POSTGRESQL_SSL_REJECT_UNAUTHORIZED=false

# Discord bot
# Configure Discord client, guild, and command settings in the dashboard.
DISCORD_BOT_TOKEN=

# Standalone bot process only.
# The bundled dev/start scripts inject these from dashboard settings.
INTERNAL_PANEL_URL=
API_KEY=
